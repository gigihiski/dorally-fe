# Frontend-only demo mode. "true" serves all backend calls from src/mocks/
# (no network). Set to "false" to use the real backend defined below.
VITE_USE_MOCKS="true"

VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""
VITE_API_BASE_URL="http://localhost:8080/api/v1"
VITE_PCX_VERIFICATION_URL="https://my.pcxfx.com"
VITE_PCX_IMAGE_BASE_URL="https://my.pcxfx.com"
VITE_GOOGLE_OAUTH_CLIENT_ID=
# PCX account type used by /pcxfx/registration. Either "demo" or "live" (default: live).
VITE_PCX_ACCOUNT_MODE="live"
